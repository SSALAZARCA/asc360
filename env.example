# =============================================
# UM Colombia — Variables de entorno
# Copiar este archivo como .env y completar
# NUNCA commitear el .env al repositorio
# =============================================

# --- Base de datos ---
POSTGRES_USER=umadmin
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=um_service_db

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# --- MinIO ---
MINIO_ROOT_USER=umadmin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_MIN12CHARS

# --- JWT (generar con: openssl rand -hex 32) ---
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_64_CHARS

# --- Secreto interno Bot Sonia (generar con: openssl rand -hex 24) ---
SONIA_BOT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO

# --- CORS: orígenes permitidos separados por coma ---
ALLOWED_ORIGINS=https://asc360.online,https://www.asc360.online

# --- URL pública de la API (la ve el navegador del cliente) ---
NEXT_PUBLIC_API_URL=https://asc360.online/api/v1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Entorno ---
ENVIRONMENT=production
